rules_version = '2';

// Owlette Firestore Security Rules
// Version: 2.4.0 - Roost pointer field rename (manifest -> version)
// Last Updated: 2026-04-28
//
// Security Model:
// - Role-based access control (RBAC): user | admin | agent
// - Multi-user site access: Users can only access sites in their assigned sites array
// - Admins can access ALL sites regardless of assignment
// - Agents use custom tokens (OAuth) with site-scoped permissions
// - Agents can ONLY access their assigned site and machine (strict isolation)
// - Trusted server APIs manage control-plane writes
// - Unauthenticated users can read installer_metadata (for public downloads)
//
// Key Features:
// - OAuth Authentication: Agents authenticate via custom tokens (no service accounts)
// - Scoped Permissions: Agents limited to their site_id + machine_id (from token claims)
// - Admin Panel: User management, site assignment, installer version management
// - Public Downloads: Anyone can download agent installers
// - Site Access: Users can only access sites they're assigned to (admins see all)
// - Command System: Bidirectional communication with agents
//
// Custom Token Claims (for agents):
// - role: 'agent' (identifies agent authentication)
// - site_id: 'site_xxx' (which site this agent belongs to - snake_case!)
// - machine_id: 'DESKTOP-001' (which machine this agent represents - snake_case!)
//
// IMPORTANT: Claim names must be snake_case (site_id, machine_id) NOT camelCase!
// Firebase custom token claims are used in security rules exactly as provided.

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // Helper Functions
    // ============================================

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user is a platform superadmin (role='superadmin' in users collection)
    // Superadmins have god-mode access across all sites and platform-wide operations
    // (installer uploads, user role management, global settings, etc).
    function isSuperadmin() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    // Check if request is from a trusted server/admin token.
    // Admin SDK bypasses rules; this supports custom-token admin clients.
    function isServiceAccount() {
      return request.auth != null &&
             ('admin' in request.auth.token) &&
             request.auth.token.admin == true;
    }

    // Check if request is from OAuth-authenticated agent
    // Agents have custom token with claims: {role: 'agent', site_id: 'xxx', machine_id: 'yyy'}
    function isAgent() {
      return request.auth != null &&
             ('role' in request.auth.token) &&
             ('site_id' in request.auth.token) &&
             ('machine_id' in request.auth.token) &&
             request.auth.token.role == 'agent' &&
             request.auth.token.site_id is string &&
             request.auth.token.machine_id is string;
    }

    // Check if user owns a site (direct ownership)
    function isSiteOwner(siteId) {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/sites/$(siteId)).data.owner == request.auth.uid;
    }

    // Check if agent has access to a specific site
    // Agents can ONLY access their assigned site (from token claim)
    function agentCanAccessSite(siteId) {
      return isAgent() && request.auth.token.site_id == siteId;
    }

    // Check if agent is accessing their own machine
    // Prevents agents from accessing other machines (even in same site)
    function agentCanAccessMachine(siteId, machineId) {
      return isAgent() &&
             request.auth.token.site_id == siteId &&
             request.auth.token.machine_id == machineId;
    }

    // Check if user has access to a site.
    // Access is granted to:
    //   - site owners (direct ownership)
    //   - superadmins (platform god-mode — every site, regardless of sites[] membership)
    //   - any user whose role is 'member' or 'admin' AND has siteId in their sites[] array
    // Returns false if user document doesn't exist (graceful handling for new users).
    function canAccessSite(siteId) {
      return isAuthenticated() && (
        isSiteOwner(siteId) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin' ||
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sites is list &&
           siteId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sites)))
      );
    }

    // Check if user is a site-scoped admin for a given site.
    // True when the user's role is 'admin' or 'superadmin' AND they can access the site.
    // - admin: role applies across every site in their sites[] array
    // - superadmin: passes canAccessSite() unconditionally (god-mode fall-through)
    // Use this for site-level elevated operations (delete machines, edit stored layouts,
    // manage site-scoped webhooks / settings) — as opposed to isSuperadmin() which is
    // reserved for platform-wide operations.
    function isSiteAdmin(siteId) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'] &&
             canAccessSite(siteId);
    }

    // Validate that required fields are present in write operations
    function hasRequiredFields(required) {
      return request.resource.data.keys().hasAll(required);
    }

    // ============================================
    // Sites Collection
    // ============================================

    match /sites/{siteId} {
      // Site document access
      // READ: Allow any authenticated user to check if site exists (for availability checking during creation)
      // WRITE: trusted server APIs only
      allow read: if canAccessSite(siteId);
      allow create, update, delete: if isServiceAccount();

      // ----------------------------------------
      // Machines Subcollection
      // ----------------------------------------

      match /machines/{machineId} {
        // Machine status document
        // Agents write heartbeats, metrics, and process status
        // Web dashboard reads machine status; control-plane writes go through API routes
        // OAuth agents can ONLY access their own machine (strict isolation)
        allow read: if canAccessSite(siteId) ||
                       isServiceAccount() ||
                       agentCanAccessMachine(siteId, machineId);

        // Allow agents full write access for metrics, heartbeats, processes.
        // Control-plane toggles (configChangeFlag, cortexEnabled, commands)
        // are server-mediated through API routes.
        allow update: if isServiceAccount() ||
                         agentCanAccessMachine(siteId, machineId);

        // Allow agents full write access for metrics, heartbeats, processes
        allow write: if isServiceAccount() ||
                        agentCanAccessMachine(siteId, machineId);

        allow delete: if isServiceAccount() ||
                         agentCanAccessMachine(siteId, machineId);

        // Commands documents (pending/completed)
        // Server APIs write pending commands
        // Agents read pending and write completed
        // OAuth agents can ONLY access commands for their own machine
        match /commands/{commandDoc} {
          allow read: if canAccessSite(siteId) ||
                         isServiceAccount() ||
                         agentCanAccessMachine(siteId, machineId);
          allow write: if isServiceAccount() ||
                          agentCanAccessMachine(siteId, machineId);
          allow delete: if isServiceAccount() ||
                           agentCanAccessMachine(siteId, machineId);
        }

        // Screenshot History Subcollection
        // Server-side API writes history entries (admin SDK bypasses rules)
        // Web dashboard reads to display screenshot history gallery
        match /screenshots/{screenshotId} {
          allow read: if canAccessSite(siteId) ||
                         isServiceAccount();
        }

        // Installed Software Inventory Subcollection
        // Agents write software inventory data
        // Web dashboard reads to display installed software
        // OAuth agents can ONLY write to their own machine's inventory
        match /installed_software/{softwareId} {
          allow read: if canAccessSite(siteId) ||
                         isServiceAccount() ||
                         agentCanAccessMachine(siteId, machineId);
          allow write: if isServiceAccount() ||
                          agentCanAccessMachine(siteId, machineId); // Only agents can write inventory
          allow delete: if canAccessSite(siteId) ||
                           isServiceAccount() ||
                           agentCanAccessMachine(siteId, machineId); // Allow cleanup
        }

        // ----------------------------------------
        // Hardware Profile Subcollection
        // ----------------------------------------
        // Stores hardware inventory/profile data for the machine
        // Agents write hardware profile on startup and on hardware changes
        // Web dashboard reads to display hardware details
        // OAuth agents can ONLY write to their own machine's hardware profile
        match /hardware/{docId} {
          allow read: if canAccessSite(siteId) ||
                         isServiceAccount() ||
                         agentCanAccessMachine(siteId, machineId);
          allow write: if isServiceAccount() ||
                          agentCanAccessMachine(siteId, machineId);
        }

        // ----------------------------------------
        // Historical Metrics Subcollection
        // ----------------------------------------
        // Stores time-series metrics for dashboard graphs
        // Daily buckets: metrics_history/{YYYY-MM-DD}
        // Fields: samples[] array with {t, c, m, d, g, ct, gt}
        // Retention: 1min (today) -> 10min (week) -> 20min (month) -> 1hr (forever)

        match /metrics_history/{bucketId} {
          // Web dashboard reads historical metrics for charts
          allow read: if canAccessSite(siteId) ||
                         isServiceAccount() ||
                         agentCanAccessMachine(siteId, machineId);

          // Agents write metrics samples (append to daily bucket)
          allow write: if isServiceAccount() ||
                          agentCanAccessMachine(siteId, machineId);

          // Cloud Functions need to aggregate and update buckets
          // Service account has full access for aggregation jobs
          allow update: if isServiceAccount() ||
                           agentCanAccessMachine(siteId, machineId);
        }
      }

      // ----------------------------------------
      // Deployments Subcollection
      // ----------------------------------------

      match /deployments/{deploymentId} {
        // Software installation deployments
        // Server APIs create and manage deployments
        allow read: if canAccessSite(siteId);
        allow create, update, delete: if isServiceAccount();
      }

      // ----------------------------------------
      // Installer Templates Subcollection
      // ----------------------------------------

      match /installer_templates/{templateId} {
        // Reusable installer templates
        // Server APIs manage templates
        allow read: if canAccessSite(siteId);
        allow create, update, delete: if isServiceAccount();
      }

      // ----------------------------------------
      // Project Templates Subcollection
      // ----------------------------------------

      match /project_templates/{templateId} {
        // Reusable project distribution templates
        // Server APIs manage templates
        allow read: if canAccessSite(siteId);
        allow create, update, delete: if isServiceAccount();
      }

      // ----------------------------------------
      // Project Distributions Subcollection
      // ----------------------------------------

      match /project_distributions/{distributionId} {
        // Project file distributions (v1, legacy)
        // Server APIs create and manage distributions
        // Coexists with roosts/ (v2 / roost) during migration
        allow read: if canAccessSite(siteId);
        allow create, update, delete: if isServiceAccount();
      }

      // ----------------------------------------
      // Roosts Subcollection (roost / v2)
      // ----------------------------------------
      // The v2 replacement for project_distributions. Each roost
      // represents a project that's kept in sync with one or more machines.
      // The doc itself stores ONLY the version pointer (currentVersionId,
      // previousVersionId, versionUrl) plus targets[] + metadata.
      // Version bodies themselves live in R2 (size: a 500GB project ~10MB
      // body, well over Firestore's 1MB doc limit).
      // schemaVersion: 2 distinguishes from v1 project_distributions.
      //
      // The old `*Manifest*` field names (currentManifestId, etc.) are
      // also blocked as defense-in-depth: legacy roost docs predate the
      // manifest->version rename and may still carry those keys, so the
      // immutability guard covers both names.

      match /roosts/{roostId} {
        allow read: if canAccessSite(siteId);
        // CREATE: site-scoped users can create the roost shell, but the
        // pointer fields (currentVersionId, previousVersionId, versionUrl —
        // and the legacy currentManifestId/previousManifestId/manifestUrl
        // names) MUST be null/unset at create time. The first real version
        // is published via /api/roosts/.../versions using the admin SDK
        // (which bypasses these rules). This prevents a direct-Firestore
        // client from publishing a fake "v0" pointing at attacker-
        // controlled storage.
        allow create: if canAccessSite(siteId) &&
                         hasRequiredFields(['name', 'targets', 'createdAt', 'schemaVersion']) &&
                         request.resource.data.schemaVersion == 2 &&
                         (!('currentVersionId' in request.resource.data) ||
                          request.resource.data.currentVersionId == null) &&
                         (!('previousVersionId' in request.resource.data) ||
                          request.resource.data.previousVersionId == null) &&
                         (!('versionUrl' in request.resource.data) ||
                          request.resource.data.versionUrl == null) &&
                         (!('currentManifestId' in request.resource.data) ||
                          request.resource.data.currentManifestId == null) &&
                         (!('previousManifestId' in request.resource.data) ||
                          request.resource.data.previousManifestId == null) &&
                         (!('manifestUrl' in request.resource.data) ||
                          request.resource.data.manifestUrl == null);
        // UPDATE: pointer fields cannot be flipped client-side. They go
        // through the /api/roosts/.../versions + /rollback routes,
        // which use Firestore transactions (CAS) under admin SDK creds.
        allow update: if canAccessSite(siteId) &&
                         !request.resource.data.diff(resource.data).affectedKeys()
                            .hasAny([
                              'currentVersionId', 'previousVersionId', 'versionUrl',
                              'currentManifestId', 'previousManifestId', 'manifestUrl',
                              'schemaVersion'
                            ]);
        allow delete: if canAccessSite(siteId);

        // ------------------------------------------
        // Per-target reported state (one doc per machine)
        // ------------------------------------------
        // Agents write their own observed state here so the dashboard can
        // show "machine X is ON version Y" vs the intended currentVersionId.
        // This closes the loop between intent (set by web) and reality
        // (reported by agent).

        match /target_state/{machineId} {
          // READ: any site member can see reported target state.
          allow read: if canAccessSite(siteId);
          // CREATE/UPDATE: ONLY the agent for this specific machine. Web
          // users cannot spoof an agent's reported state (would let a
          // malicious teammate hide pending rollouts by marking a machine
          // as already-synced when it isn't).
          allow create, update: if isAgent() &&
                                  request.auth.token.site_id == siteId &&
                                  request.auth.token.machine_id == machineId;
          // DELETE: site members can clear stale state (manual cleanup
          // when an agent is decommissioned). Agents do not delete their
          // own state — they update it.
          allow delete: if canAccessSite(siteId);
        }

        // ------------------------------------------
        // Manifest history (immutable)
        // ------------------------------------------
        // Each finalized manifest is recorded here for the rollback UI.
        // The manifest CONTENT lives in R2; this collection just holds
        // metadata + the R2 url + timestamps + author for the version
        // history dropdown.

        match /versions/{versionId} {
          // READ: any site member can list version history (for rollback ui).
          allow read: if canAccessSite(siteId);
          // CREATE: forbidden client-side. Versions are written ONLY by
          // /api/roosts/.../versions using the admin SDK, after the
          // chunk-presence check + r2 version body upload + transactional
          // pointer flip on the parent. Allowing client-side create would
          // let a site member publish a fake history entry pointing at
          // attacker-controlled storage (versionUrl is unvalidated).
          allow create: if false;
          // UPDATE/DELETE: history is immutable. Rollback works by
          // repointing currentVersionId on the parent roosts
          // doc, NOT by editing or deleting versions here. GC is admin
          // SDK only (bypasses these rules) and tombstone-protected.
          allow update: if false;
          allow delete: if false;
        }
      }

      // ----------------------------------------
      // Webhooks Subcollection
      // ----------------------------------------

      match /webhooks/{webhookId} {
        // Webhook notification endpoints
        // READ: any user with site access (superadmins fall through via canAccessSite)
        // WRITE: trusted server APIs only
        allow read: if canAccessSite(siteId);
        allow write: if isServiceAccount();
      }

      // ----------------------------------------
      // Logs Subcollection
      // ----------------------------------------

      match /logs/{logId} {
        // Event logs (process starts, crashes, kills, commands)
        // Agents write logs when events occur
        // Web dashboard reads logs for monitoring
        // Users can read logs for their sites. Agents and trusted server APIs
        // write logs; clearing logs is server-mediated.
        allow read: if canAccessSite(siteId) ||
                       isServiceAccount() ||
                       agentCanAccessSite(siteId);
        allow create: if (isServiceAccount() ||
                          agentCanAccessSite(siteId)) &&
                         hasRequiredFields(['timestamp', 'action', 'level', 'machineId']) &&
                         (!isAgent() || request.resource.data.machineId == request.auth.token.machine_id);
        allow delete: if isServiceAccount();
      }

      // ----------------------------------------
      // Audit Log Subcollection
      // ----------------------------------------

      match /audit_log/{entryId} {
        // Audit entries are written by server APIs. Site admins can inspect
        // their site's audit trail; superadmins pass through isSiteAdmin().
        allow read: if isSiteAdmin(siteId);
        allow write: if false;
      }
    }

    // ============================================
    // Config Collection
    // ============================================

    match /config/{siteId}/machines/{machineId} {
      // Machine configuration (process lists, settings)
      // Server APIs write config updates
      // Agents read config and write initial config on first startup
      // OAuth agents can ONLY access config for their own machine
      allow read: if canAccessSite(siteId) ||
                     isServiceAccount() ||
                     agentCanAccessMachine(siteId, machineId);
      allow write: if isServiceAccount() ||
                      agentCanAccessMachine(siteId, machineId);
      allow delete: if isServiceAccount() ||
                       agentCanAccessMachine(siteId, machineId);
    }

    match /config/{siteId}/schedule_presets/{presetId} {
      // Schedule presets for process scheduling
      // Users with site access can read presets; server APIs manage them
      allow read: if canAccessSite(siteId);
      allow write, delete: if isServiceAccount();
    }

    match /config/{siteId}/reboot_presets/{presetId} {
      // Reboot schedule presets shared across machines in a site
      // Users with site access can read presets; server APIs manage them
      allow read: if canAccessSite(siteId);
      allow write, delete: if isServiceAccount();
    }

    match /config/{siteId}/project_distribution_presets/{presetId} {
      // Project distribution presets shared across a site
      // Users with site access can read presets; server APIs manage them
      allow read: if canAccessSite(siteId);
      allow write, delete: if isServiceAccount();
    }

    // ============================================
    // Users Collection (Admin System)
    // ============================================

    match /users/{userId} {
      // User profiles with role and site access
      // Users can read their own document
      // Superadmins can read all user documents; writes are server-mediated
      allow read: if isAuthenticated() && (request.auth.uid == userId || isSuperadmin());

      // Users can create their own document (on first login).
      // Role is pinned to 'member' on self-create — privilege elevation must go
      // through a trusted server path (isServiceAccount). Without this guard, a
      // newly-signed-up user could write `role: 'superadmin'` and own the platform.
      allow create: if request.auth.uid == userId &&
                       (!('role' in request.resource.data) ||
                        request.resource.data.role == 'member');

      // Users can update their own sites array (when creating sites)
      // Users can update MFA fields (mfaEnrolled, mfaSecret, backupCodes, requiresMfaSetup)
      // But cannot change their role or other sensitive fields
      allow update: if request.auth.uid == userId &&
                       request.resource.data.role == resource.data.role &&
                       request.resource.data.email == resource.data.email &&
                       request.resource.data.sites == resource.data.sites;

      // Trusted server APIs manage user roles, site assignments, and deletion.
      allow write: if isServiceAccount();
    }

    // ============================================
    // Installer Metadata Collection (Admin System)
    // ============================================

    match /installer_metadata/{document=**} {
      // Agent installer versions and metadata
      // PUBLIC READ: Anyone can download installers (unauthenticated allowed)
      // ADMIN WRITE: trusted server APIs upload/modify installer versions
      allow read: if true;  // Public read for download button
      allow write: if isServiceAccount();
    }

    // ============================================
    // System Presets Collection
    // ============================================

    match /system_presets/{presetId} {
      // Global software deployment presets (Owlette Agent, TouchDesigner, etc.)
      // READ: All authenticated users can see presets
      // WRITE: trusted server APIs create/update/delete presets
      allow read: if isAuthenticated();

      // Platform-level presets are managed through server routes.
      allow create: if isServiceAccount();

      // Update and delete: trusted server APIs only
      allow update, delete: if isServiceAccount();
    }

    // ============================================
    // API Keys Subcollection
    // ============================================

    match /users/{userId}/api_keys/{keyId} {
      // Users can read their own key inventory (for settings UI).
      // Fields stored: name, keyPrefix, environment, scopes, expiresAt,
      // createdAt, lastUsedAt, rotatedAt, revokedAt (never the raw key or hash).
      // Writes are admin-SDK-only (route handlers) — client writes denied.
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if false;
    }

    // Top-level api_keys lookup table (keyHash → userId + keyId + scopes).
    // Never accessible client-side — admin SDK only.
    match /api_keys/{keyHash} {
      allow read, write: if false;
    }

    // ============================================
    // User Settings Subcollection
    // ============================================

    match /users/{userId}/settings/{settingId} {
      // User-level settings (e.g., LLM API keys)
      // Users can only read/write their own settings
      // Admin SDK handles encryption server-side
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId}/devicePrefs/{docId} {
      // Per-device UI preferences (e.g., view mode, collapse state)
      // Users can only read/write their own device preferences
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // ============================================
    // Site Settings Subcollection
    // ============================================

    match /sites/{siteId}/settings/{settingId} {
      // Site-level settings (e.g., shared LLM API keys)
      // Trusted server APIs manage site-level settings
      // Regular users can read (to check if site key exists)
      allow read: if canAccessSite(siteId);
      allow write: if isServiceAccount();
    }

    // ============================================
    // Chat Conversations Collection
    // ============================================

    match /chats/{chatId} {
      // AI chat conversations
      // Users can read their own chats OR autonomous chats for sites they have access to
      allow read: if isAuthenticated() &&
                     (resource.data.userId == request.auth.uid ||
                      (resource.data.source == 'autonomous' &&
                       canAccessSite(resource.data.siteId)));
      allow create: if isAuthenticated() &&
                     (request.resource.data.userId == request.auth.uid ||
                      request.resource.data.source == 'autonomous');
      allow update, delete: if isAuthenticated() &&
                               resource.data.userId == request.auth.uid;

      match /messages/{messageId} {
        // Chat messages within a conversation
        // Access controlled by parent chat ownership OR autonomous chat site access
        allow read: if isAuthenticated() &&
                       (get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid ||
                        (get(/databases/$(database)/documents/chats/$(chatId)).data.source == 'autonomous' &&
                         canAccessSite(get(/databases/$(database)/documents/chats/$(chatId)).data.siteId)));
        allow write: if isAuthenticated() &&
                        get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
      }
    }

    // ============================================
    // OAuth Token Collections (Server-Side Only)
    // ============================================

    match /agent_tokens/{tokenId} {
      // Registration codes for agent installer OAuth flow
      // SECURITY: Only accessible via server-side Admin SDK
      // Never allow client-side access (prevents token theft)
      allow read, write: if false;
    }

    match /agent_refresh_tokens/{tokenHash} {
      // Refresh tokens for agent authentication
      // SECURITY: Only accessible via server-side Admin SDK
      // Tokens are stored hashed for additional security
      allow read, write: if false;
    }

    match /device_codes/{phrase} {
      // Device code pairing phrases for device-code auth flow
      // SECURITY: Only accessible via server-side Admin SDK
      // Contains temporary tokens during pairing handshake
      allow read, write: if false;
    }

    // ============================================
    // Deny All Other Paths
    // ============================================

    // Explicitly deny access to any other documents
    // This prevents accidental data leaks
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
