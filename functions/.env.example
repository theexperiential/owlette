# Cloud Function environment variables
# Copy to .env and fill in values

# Shared secret for internal API authentication (must match web/.env.local)
CORTEX_INTERNAL_SECRET=your_secret_here

# API base URL is auto-derived from Firebase project ID:
#   project contains "dev" → https://dev.owlette.app
#   otherwise             → https://owlette.app
# Uncomment to override:
# API_BASE_URL=https://dev.owlette.app
