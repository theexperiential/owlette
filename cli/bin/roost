#!/usr/bin/env node
// Deprecation wrapper for the legacy `roost` binary name. Prints a one-time
// migration notice to stderr, then delegates to ./owlette so existing
// scripts and muscle memory keep working.
//
// Removal target: 2026-10-01 (6 months after rename). After that date, drop
// this file + the `roost` bin entry in package.json. See cli/MIGRATION.md.

'use strict';

process.stderr.write(
  '[owlette] the `roost` binary is deprecated; use `owlette` instead. ' +
    'this wrapper will be removed on 2026-10-01. see cli/MIGRATION.md.\n',
);

require('./owlette');
