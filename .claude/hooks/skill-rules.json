{
  "skills": {
    "frontend-dev-guidelines": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Next.js/React/TypeScript patterns for web dashboard",
      "promptTriggers": {
        "keywords": [
          "frontend",
          "react",
          "next",
          "nextjs",
          "component",
          "dashboard",
          "UI",
          "interface",
          "page",
          "route",
          "web",
          "client",
          "tailwind",
          "shadcn",
          "typescript"
        ],
        "intentPatterns": [
          "(create|add|build|make).*?(component|page|route|interface|UI)",
          "(how to|best practice).*?(react|next|frontend|component)",
          "(fix|debug).*?(component|page|rendering|UI)",
          "(style|design).*?(component|page|UI)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "web/app/**/*.tsx",
          "web/app/**/*.ts",
          "web/components/**/*.tsx",
          "web/hooks/**/*.ts",
          "web/lib/**/*.ts",
          "web/contexts/**/*.tsx"
        ]
      }
    },

    "backend-dev-guidelines": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Python Windows service patterns for agent",
      "promptTriggers": {
        "keywords": [
          "backend",
          "python",
          "agent",
          "service",
          "process",
          "monitor",
          "windows",
          "psutil",
          "pywin32"
        ],
        "intentPatterns": [
          "(create|add|build).*?(service|process|monitor)",
          "(how to|best practice).*?(python|backend|service|windows)",
          "(fix|debug).*?(service|process|crash|agent)",
          "(monitor|track|manage).*?process"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "agent/src/**/*.py"
        ]
      }
    },

    "firebase-integration": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Firebase Auth and Firestore integration patterns",
      "promptTriggers": {
        "keywords": [
          "firebase",
          "firestore",
          "auth",
          "authentication",
          "real-time",
          "realtime",
          "listener",
          "sync",
          "cloud",
          "database"
        ],
        "intentPatterns": [
          "(connect|integrate|setup).*?(firebase|firestore)",
          "(how to|best practice).*?(firebase|firestore|auth)",
          "(read|write|update|delete|query).*?(firestore|firebase)",
          "(listen|subscribe|watch).*?(firestore|real-time)",
          "(sign in|login|logout|authenticate).*?(firebase|auth)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "web/lib/firebase.ts",
          "web/contexts/AuthContext.tsx",
          "web/hooks/useFirestore.ts",
          "web/hooks/useDeployments.ts",
          "agent/src/firebase_client.py",
          "agent/src/firestore_rest_client.py",
          "agent/src/auth_manager.py",
          "agent/src/connection_manager.py"
        ]
      }
    },

    "testing-guidelines": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "medium",
      "description": "Testing patterns for Jest/pytest",
      "promptTriggers": {
        "keywords": [
          "test",
          "testing",
          "jest",
          "pytest",
          "spec",
          "unit test",
          "integration test",
          "e2e",
          "mock",
          "coverage"
        ],
        "intentPatterns": [
          "(write|create|add).*?test",
          "(how to|best practice).*?test",
          "(run|execute).*?test",
          "(mock|stub|spy).*?(function|component|service)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "web/__tests__/**/*.ts",
          "web/__tests__/**/*.tsx",
          "web/**/*.test.ts",
          "web/**/*.test.tsx",
          "web/**/*.spec.ts",
          "web/**/*.spec.tsx",
          "agent/tests/**/*.py",
          "agent/**/*_test.py",
          "agent/**/test_*.py"
        ]
      }
    },

    "build-system": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Installer build pipeline, Inno Setup, NSSM service management, self-update",
      "promptTriggers": {
        "keywords": [
          "installer",
          "build",
          "inno setup",
          "ISCC",
          "nssm",
          "package",
          "deploy agent",
          "update agent",
          "self-update",
          "embedded python",
          "version bump",
          "release"
        ],
        "intentPatterns": [
          "(build|compile|create|package).*?(installer|agent|release)",
          "(install|deploy|update|upgrade).*?(agent|service|owlette)",
          "(how to|best practice).*?(build|installer|deploy|release)",
          "(fix|debug).*?(build|installer|install|update|nssm)",
          "(configure|setup).*?(nssm|service|windows service)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "agent/build_installer_full.bat",
          "agent/build_installer_quick.bat",
          "agent/owlette_installer.iss",
          "agent/scripts/*.bat",
          "agent/src/owlette_updater.py",
          "agent/src/owlette_runner.py",
          "agent/src/configure_site.py",
          "agent/src/installer_utils.py",
          "agent/VERSION",
          "VERSION",
          "scripts/sync-versions.js"
        ]
      }
    }
  },

  "activationConfig": {
    "maxSkillsPerPrompt": 3,
    "priorityOrder": ["high", "medium", "low"],
    "requireExactKeywordMatch": false,
    "caseSensitive": false,
    "fileEditLookbackMinutes": 10
  }
}
