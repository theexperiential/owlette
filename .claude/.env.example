# .claude environment overrides — copy to .claude/.env.local and fill in
# This file documents what's expected; the actual values live in .env.local (gitignored)

# OWLETTE API key for installer uploads (3-step API flow per CLAUDE.md)
# Generate from owlette.app Admin > API Keys with installer=*:write scope (superadmin-only)
# Format: owk_xxx
OWLETTE_API_KEY=owk_replace_with_your_admin_key
