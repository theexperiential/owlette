# @ai-sdk/react@3.x declares a react peer range (~19.1.2 || ^19.2.1) that
# excludes our pinned react@19.2.0, so a clean `npm install` fails with
# ERESOLVE on platforms that re-resolve peers (Vercel, CI). The committed
# package-lock.json already encodes a working tree; legacy-peer-deps keeps
# installs from re-litigating the peer conflict. Remove once react is bumped
# to >=19.2.1 (or @ai-sdk/react widens its peer range).
legacy-peer-deps=true
