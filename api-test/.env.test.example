# Owlette Integration Test Configuration
# Copy to .env.test and fill in values

# API endpoint (dev environment)
OWLETTE_API_URL=https://dev.owlette.app
OWLETTE_API_KEY=owk_your_test_api_key_here

# Target site and machine for tests
OWLETTE_SITE_ID=your-test-site-id
OWLETTE_MACHINE_ID=your-test-machine-id

# Optional: timeout for wait-mode command tests (seconds)
OWLETTE_COMMAND_TIMEOUT=30
