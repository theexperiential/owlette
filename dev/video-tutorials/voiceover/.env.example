# Copy to .env and fill in. .env is gitignored (see .gitignore in this folder).
# A paid ElevenLabs plan is required for commercial usage rights on generated audio.

# Required for real generation (omit for --dry-run).
ELEVENLABS_API_KEY=

# The voice to narrate with. Find/clone a voice in the ElevenLabs dashboard, then copy
# its voice id here. List voices via:  GET https://api.elevenlabs.io/v1/voices
ELEVENLABS_VOICE_ID=

# Model. Default is the stable long-form pick. Switch to eleven_v3 for the more
# expressive intro episodes (enables [warm]/[pause] audio tags in the scripts).
#   eleven_multilingual_v2  - stable, neutral, broadly available (DEFAULT)
#   eleven_v3               - most expressive; honors audio tags; not for real-time
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
